# Copy this file to ".env" (same folder) and fill in your real key.
#   cp .env.example .env
# The .env file is git-ignored, so your key never gets committed or published.

# Get a key from https://console.anthropic.com  →  Settings  →  API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the default Claude model used across the course.
# Leave commented to use the course default (a good balance of speed/cost/quality).
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional: override the local Ollama model used in the free/local exercises.
# OLLAMA_MODEL=llama3.2
# OLLAMA_EMBED_MODEL=nomic-embed-text
